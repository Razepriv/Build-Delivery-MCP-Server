# Build Delivery MCP — environment variables
# All values here are optional overrides for the config.json file.
# JSON config takes precedence once written; env vars are used for first-run bootstrap.

# ─── Config & runtime ──────────────────────────────────────────────
CONFIG_PATH=./config.json
LOG_LEVEL=info
STAGING_DIR=./.staging

# ─── Default profile ───────────────────────────────────────────────
DEFAULT_PROFILE=default
DEFAULT_CHANNEL=telegram

# ─── Telegram ──────────────────────────────────────────────────────
# Get a bot token from @BotFather on Telegram, then add the bot to your
# group/channel and use @userinfobot to find the chat ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── WhatsApp (whatsapp-web.js) ────────────────────────────────────
# Session is QR-based. First run prints a QR code; scan with your phone
# (WhatsApp → Linked Devices → Link a Device). Subsequent runs restore.
# Recipient IDs: contacts use `<number>@c.us`, groups use `<id>@g.us`.
WHATSAPP_ENABLED=true
WHATSAPP_SESSION_PATH=./.wwebjs_auth/default
WHATSAPP_RECIPIENTS=

# ─── Slack ─────────────────────────────────────────────────────────
# Create a Slack app, install it to your workspace, and grab the bot
# user OAuth token (xoxb-…). The bot needs `files:write` and
# `chat:write` scopes; invite it to each channel you target.
SLACK_BOT_TOKEN=
SLACK_CHANNELS=

# ─── Discord ───────────────────────────────────────────────────────
# Server settings → Integrations → Webhooks → New Webhook.
# Comma-separate multiple webhook URLs.
DISCORD_WEBHOOK_URL=

# ─── Email (SMTP) ──────────────────────────────────────────────────
# Standard SMTP envelope. For Gmail, use an App Password
# (https://myaccount.google.com/apppasswords) — not your account password.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_RECIPIENTS=

# ─── Microsoft Teams ───────────────────────────────────────────────
# Channel → Connectors → Incoming Webhook. Teams cannot accept file
# attachments via webhooks; this channel delivers a notification card
# only (build name, version, size). Route the file through a different
# channel (Telegram / Slack / Discord / Email).
TEAMS_WEBHOOK_URL=

# ─── File watcher ──────────────────────────────────────────────────
WATCH_DIRECTORY=./builds
WATCH_EXTENSIONS=.apk,.aab,.ipa
WATCH_STABILITY_MS=2000

# ─── Naming ────────────────────────────────────────────────────────
NAMING_PATTERN={appName}_v{version}_{buildType}_{date}_{time}

# ─── Limits ────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
WHATSAPP_MAX_MB=2048
SLACK_MAX_MB=1024
DISCORD_MAX_MB=25
EMAIL_MAX_MB=25

# ─── Android SDK (for aapt resolution) ─────────────────────────────
ANDROID_HOME=
BUNDLETOOL_PATH=

# ─── Distribution Intelligence (Phase 3 — all optional) ────────────

# Changelog generation: include git-log between tags in delivery captions.
INTEL_CHANGELOG_ENABLED=false
INTEL_CHANGELOG_REPO=

# Crashlytics correlation: previous-version stability alongside the build.
# Source can be 'file' (local JSON) or 'http' (endpoint returning the same shape).
INTEL_CRASHLYTICS_ENABLED=false
INTEL_CRASHLYTICS_SOURCE=
INTEL_CRASHLYTICS_PATH=
INTEL_CRASHLYTICS_AUTH_HEADER=

# Install tracking: opt-in local HTTP server that serves builds via unique
# tokens and records each click/download. baseUrl is what gets embedded in
# captions — point this at whatever the operator exposes (ngrok / Tailscale
# / cloudflared / your own reverse proxy). perRecipient=true issues a
# distinct token per (channel, recipient) so install events are attributable.
INTEL_TRACKING_ENABLED=false
INTEL_TRACKING_BASE_URL=
INTEL_TRACKING_PORT=7331
INTEL_TRACKING_PER_RECIPIENT=false
# Trust X-Forwarded-For for client IP (only set true when a reverse proxy
# is in front of the tracker — never trust it on a directly-exposed port).
INTEL_TRACKING_TRUST_PROXY=false
